# Google OAuth2 credentials (from Google Cloud Console > OAuth 2.0 Client IDs > Desktop app)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Google Cloud Pub/Sub (for Gmail push notifications)
PUBSUB_PROJECT_ID=your-project-id
PUBSUB_SUBSCRIPTION_ID=gmail-notifications-pull
PUBSUB_TOPIC=projects/your-project-id/topics/gmail-notifications

# Gemini API Key (Optional if using Generative Language API via OAuth)
GEMINI_API_KEY=your_gemini_api_key
