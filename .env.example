# Google OAuth2 credentials (from Google Cloud Console > OAuth 2.0 Client IDs > Desktop app)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Google Cloud Pub/Sub (for Gmail push notifications)
PUBSUB_PROJECT_ID=your-project-id
PUBSUB_SUBSCRIPTION_ID=gmail-notifications-pull
PUBSUB_TOPIC=projects/your-project-id/topics/gmail-notifications

# Gemini API Key (Optional if using Generative Language API via OAuth)
GEMINI_API_KEY=your_gemini_api_key

# Slack OAuth2 (from api.slack.com > Your App > Basic Information)
SLACK_APP_ID=your_slack_app_id
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_VERIFICATION_TOKEN=your_slack_verification_token
SLACK_APP_LEVEL_TOKEN=xapp-1-your_app_level_token
SLACK_REDIRECT_URI=http://localhost:9005/slack/oauth2callback

# Cloudflare Worker proxy (for Slack and Fireflies credential proxying)
PROXY_BASE_URL=https://your-worker-name.your-subdomain.workers.dev
PROXY_APP_TOKEN=your_shared_app_token

# Fireflies API key lives in the Cloudflare Worker secret, NOT here.
# Add it via: echo "your-key" | wrangler secret put FIREFLIES_API_KEY
